# Background Jobs (Upstash QStash)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Email (Resend)
RESEND_API_KEY=

# Logging (optional: debug, info, warn, error)
LOG_LEVEL=info
